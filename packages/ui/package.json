{
  "name": "@ai-agencee/ui",
  "version": "0.1.0",
  "description": "Shared React UI component library — formular.dev bridge, atoms, molecules, DAG canvas",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./formular-bridge": "./src/formular-bridge/index.ts",
    "./form": "./src/form/index.ts",
    "./atoms": "./src/atoms/index.ts",
    "./molecules": "./src/molecules/index.ts",
    "./dag": "./src/dag/index.ts",
    "./tokens": "./src/tokens/index.ts",
    "./icons": "./src/icons/index.tsx",
    "./tailwind.preset": "./tailwind.preset.cjs",
    "./fast-table": "./src/fast-table/index.ts",
    "./layout-engine": "./src/layout-engine/index.ts"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pulsar-framework/formular.dev": ">=1",
    "react": ">=18",
    "react-dom": ">=18"
  },
