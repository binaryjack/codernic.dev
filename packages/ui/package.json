      "optional": true
    }
  },
  "devDependencies": {
    "@pulsar-framework/formular.dev": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.52",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@xyflow/react": "^12.7.0",
    "dagre": "^0.8.5",
    "jsdom": "^29.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.4.5",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@binaryjack/state-factories": "workspace:*"
  }
