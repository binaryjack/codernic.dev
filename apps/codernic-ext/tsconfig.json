{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "sourceMap": true,
    "noEmit": true
  },
  "include": ["src/**/*", "../codernic-ui/src/ui"],
  "exclude": ["node_modules", "dist"]
}
