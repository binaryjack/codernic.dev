{
  "name": "codernic-ext",
  "displayName": "Codernic",
  "description": "Codernic — author agents, DAGs, rules and run workflows directly from VS Code",
  "version": "0.6.238",
  "publisher": "binaryjack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/binaryjack/codernic.dev.git"
  },
  "homepage": "https://codernic.dev",
  "private": true,
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-agencee-tc",
          "title": "AI Agencee",
          "icon": "media/activitybar-icon.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "ai-agencee-codernic",
          "title": "Codernic Mission Control",
          "icon": "media/activitybar-icon.svg"
        },
        {
          "id": "ai-agencee-schemas",
          "title": "Erathos",
          "icon": "media/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "ai-agencee-tc": [
        {
          "type": "tree",
          "id": "tc.assets",
          "name": "Assets",
          "icon": "media/icon.svg"
        },
        {
          "type": "tree",
          "id": "ai-agencee-indexed-files",
          "name": "Indexed Files",
          "icon": "$(database)",
          "visibility": "visible"
        },
        {
          "type": "tree",
          "id": "ai-agencee-symbol-explorer",
          "name": "Symbol Explorer",
          "icon": "$(symbol-class)",
          "visibility": "visible"
        }
      ],
      "ai-agencee-codernic": [
        {
          "type": "webview",
          "id": "ac.codernic",
          "name": "Codernic",
          "icon": "media/icon.svg"
        }
      ],
      "ai-agencee-schemas": [
        {
          "type": "webview",
          "id": "ai-agencee.schemas",
          "name": "Erathos"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "ai-agencee.kit",
        "name": "ai-kit",
        "fullName": "AI Agencee",
        "description": "Author agents, DAGs, rules and run ai-kit workflows",
        "isSticky": true,
        "commands": [
          {
            "name": "create-agent",
            "description": "Scaffold a new agent JSON"
          },
          {
            "name": "create-dag",
            "description": "Scaffold a new DAG JSON"
          },
          {
            "name": "create-rule",
            "description": "Add/update a rule in .ai/rules.md"
          },
          {
            "name": "index",
            "description": "Index the codebase for intelligent search"
          },
          {
            "name": "run",
            "description": "Execute an ai-kit CLI command"
          },
          {
            "name": "dag",
            "description": "Run the DAG orchestrator"
          }
        ]
      },
      {
        "id": "ai-agencee.codernic",
        "name": "codernic",
        "fullName": "Codernic - Codebase-Aware Assistant",
        "description": "Ask questions, plan features, or execute changes with full codebase context",
        "isSticky": true,
        "commands": [
          {
            "name": "ask",
            "description": "Q&A mode - answer questions about the codebase"
          },
          {
            "name": "plan",
            "description": "Plan mode - design features without executing"
          },
          {
            "name": "agent",
            "description": "Agent mode - execute commands and make changes"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "ai-agencee.openTui",
        "title": "AI Agencee: Open Terminal Buddy",
        "icon": "$(terminal)"
      },
      {
        "command": "ai-agencee.openCodernic",
        "title": "AI Agencee: Open Codernic Mission Control",
        "icon": "$(code)"
      },
      {
        "command": "ai-agencee.showLogs",
        "title": "AI Agencee: Show Logs",
        "icon": "$(output)"
      },
      {
        "command": "ai-agencee.restartMcp",
        "title": "AI Agencee: Restart MCP Server",
        "icon": "$(debug-restart)"
      },
      {
        "command": "ai-agencee.buildEngine",
        "title": "AI Agencee: Build Ragtime Engine",
        "icon": "$(tools)"
      },
      {
        "command": "ai-agencee.code.index",
        "title": "AI Agencee: Index Codebase",
        "icon": "$(database)"
      },
      {
        "command": "ai-agencee.code.watch",
        "title": "AI Agencee: Watch for Changes",
        "icon": "$(eye)"
      },
      {
        "command": "ai-agencee.code.stats",
        "title": "AI Agencee: Show Code Stats",
        "icon": "$(graph)"
      },
      {
        "command": "ai-agencee.validate-index",
        "title": "AI Agencee: Validate Index",
        "icon": "$(check)"
      },
      {
        "command": "ai-agencee.index-health-report",
        "title": "AI Agencee: Index Health Report",
        "icon": "$(pulse)"
      },
      {
        "command": "ai-agencee.selectModel",
        "title": "AI Agencee: Select Language Model",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "ai-agencee.showWelcome",
        "title": "AI Agencee: Show Welcome",
        "icon": "$(heart)"
      },
      {
        "command": "ai-agencee.showQualityGates",
        "title": "AI Agencee: Show Quality Gates",
        "icon": "$(checklist)"
      },
      {
        "command": "ai-agencee.tc.agent.add",
        "title": "Add Agent",
        "icon": "$(add)"
      },
      {
        "command": "ai-agencee.tc.agent.rename",
        "title": "Rename Agent",
        "icon": "$(edit)"
      },
      {
        "command": "ai-agencee.tc.agent.delete",
        "title": "Delete Agent",
        "icon": "$(trash)"
      },
      {
        "command": "ai-agencee.tc.tech.add",
        "title": "Add Technology",
        "icon": "$(add)"
      },
      {
        "command": "ai-agencee.tc.tech.rename",
        "title": "Rename Technology",
        "icon": "$(edit)"
      },
      {
        "command": "ai-agencee.indexed-files.refresh",
        "title": "Refresh Indexed Files",
        "icon": "$(refresh)"
      },
      {
        "command": "ai-agencee.symbol-explorer.refresh",
        "title": "Refresh Symbol Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "ai-agencee.search-symbols",
        "title": "AI Agencee: Search Symbols",
        "icon": "$(search)"
      },
      {
        "command": "ai-agencee.show-symbol-context",
        "title": "Show Symbol Context",
        "icon": "$(info)"
      },
      {
        "command": "ai-agencee.show-call-graph",
        "title": "Show Call Graph",
        "icon": "$(graph-line)"
      },
      {
        "command": "ai-agencee.show-dependency-graph",
        "title": "Show Dependency Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "ai-agencee.show-file-dependencies",
        "title": "Show File Dependencies",
        "icon": "$(references)"
      },
      {
        "command": "ai-agencee.show-analytics-dashboard",
        "title": "Show Analytics Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "ai-agencee.tc.tech.delete",
        "title": "Delete Technology",
        "icon": "$(trash)"
      },
      {
        "command": "ai-agencee.schemas.openCanvas",
        "title": "Open Schema Canvas",
        "category": "AI Agencee"
      },
      {
        "command": "codernic.addFileToContext",
        "title": "Add To Codernic Context",
        "category": "Codernic"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ai-agencee.openChat",
          "when": "view == tc.assets",
          "group": "navigation@1"
        },
        {
          "command": "ai-agencee.openCodernic",
          "when": "view == tc.assets",
          "group": "navigation@2"
        },
        {
          "command": "ai-agencee.tc.agent.add",
          "when": "view == tc.assets",
          "group": "navigation@3"
        },
        {
          "command": "ai-agencee.indexed-files.refresh",
          "when": "view == ai-agencee-indexed-files",
          "group": "navigation@1"
        },
        {
          "command": "ai-agencee.symbol-explorer.refresh",
          "when": "view == ai-agencee-symbol-explorer",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "ai-agencee.tc.agent.add",
          "when": "view == tc.assets && viewItem == group-agents",
          "group": "1_crud@1"
        },
        {
          "command": "ai-agencee.tc.agent.rename",
          "when": "view == tc.assets && viewItem == agent",
          "group": "1_crud@2"
        },
        {
          "command": "ai-agencee.tc.agent.delete",
          "when": "view == tc.assets && viewItem == agent",
          "group": "1_crud@3"
        },
        {
          "command": "ai-agencee.tc.tech.add",
          "when": "view == tc.assets && viewItem == group-techs",
          "group": "1_crud@1"
        },
        {
          "command": "ai-agencee.tc.tech.rename",
          "when": "view == tc.assets && viewItem == tech",
          "group": "1_crud@2"
        },
        {
          "command": "ai-agencee.tc.tech.delete",
          "when": "view == tc.assets && viewItem == tech",
          "group": "1_crud@3"
        },
        {
          "command": "ai-agencee.show-symbol-context",
          "when": "view == ai-agencee-symbol-explorer && viewItem == symbol",
          "group": "1_context@1"
        },
        {
          "command": "ai-agencee.show-call-graph",
          "when": "view == ai-agencee-symbol-explorer && viewItem == symbol",
          "group": "1_context@2"
        },
        {
          "command": "ai-agencee.show-file-dependencies",
          "when": "view == ai-agencee-indexed-files && viewItem == indexedFile",
          "group": "1_context@1"
        }
      ],
      "explorer/context": [
        {
          "command": "codernic.addFileToContext",
          "group": "codernic@1",
          "when": "resourceScheme == file"
        }
      ],
      "editor/context": [
        {
          "command": "codernic.addFileToContext",
          "group": "codernic@1",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "AI Agencee",
      "properties": {
        "ai-agencee.mcpPath": {
          "type": "string",
          "default": "",
          "description": "Path to ai-kit-mcp binary (leave empty to auto-detect from workspace)"
        },
        "ai-agencee.model": {
          "type": "string",
          "default": "copilot-gpt-4o",
          "description": "VS Code language model to use for chat"
        },
        "aiAgencee.indexing.languages": {
          "type": "array",
          "default": [
            "typescript",
            "javascript"
          ],
          "description": "Programming languages to include in code indexing",
          "items": {
            "type": "string"
          }
        },
        "aiAgencee.indexing.excludePatterns": {
          "type": "array",
          "default": [
            "node_modules",
            "dist",
            "build",
            ".git",
            "coverage",
            "**/*.min.js"
          ],
          "description": "Glob patterns to exclude from indexing",
          "items": {
            "type": "string"
          }
        },
        "aiAgencee.indexing.includePatterns": {
          "type": "array",
          "default": [],
          "description": "Glob patterns to force include (overrides .gitignore)",
          "items": {
            "type": "string"
          }
        },
        "aiAgencee.indexing.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Respect .gitignore files when discovering files to index"
        },
        "aiAgencee.indexing.forceIncludePatterns": {
          "type": "array",
          "default": [],
          "description": "Force-include patterns that override .gitignore exclusions (e.g., [\"_private/**\"])",
          "items": {
            "type": "string"
          }
        },
        "aiAgencee.indexing.autoIndexOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically index workspace on open if index is missing or stale"
        },
        "ai-agencee.indexing.autoReindex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic re-indexing on workspace open"
        },
        "ai-agencee.indexing.autoReindex.stalenessThresholdHours": {
          "type": "number",
          "default": 24,
          "description": "Re-index if index is older than this many hours",
          "minimum": 1
        },
        "ai-agencee.indexing.autoReindex.promptBeforeIndexing": {
          "type": "boolean",
          "default": true,
          "description": "Prompt user before automatically re-indexing"
        },
        "ai-agencee.indexing.fileWatcher.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable file watcher for automatic incremental re-indexing"
        },
        "ai-agencee.indexing.fileWatcher.debounceMs": {
          "type": "number",
          "default": 5000,
          "description": "Debounce delay in milliseconds before triggering reindex",
          "minimum": 1000
        },
        "ai-agencee.indexing.fileWatcher.batchSize": {
          "type": "number",
          "default": 50,
          "description": "Number of changed files that triggers immediate reindex",
          "minimum": 1
        },
        "aiAgencee.indexing.reindexOnFileChange": {
          "type": "boolean",
          "default": true,
          "description": "Automatically re-index when files change (with debouncing)"
        },
        "aiAgencee.indexing.statusBarShowSymbols": {
          "type": "boolean",
          "default": true,
          "description": "Show symbol count instead of file count in status bar"
        },
        "aiAgencee.indexing.statusBarUpdateInterval": {
          "type": "number",
          "default": 10000,
          "description": "Status bar update interval in milliseconds (minimum 5000)",
          "minimum": 5000
        },
        "aiAgencee.indexing.progressLocation": {
          "type": "string",
          "enum": [
            "notification",
            "statusbar",
            "both"
          ],
          "default": "both",
          "description": "Where to show indexing progress updates"
        },
        "ai-agencee.notifications": {
          "type": "string",
          "enum": [
            "all",
            "errors-only",
            "silent"
          ],
          "enumDescriptions": [
            "Show all toast notifications (default behaviour).",
            "Show only error toasts; replace info/warning toasts with a brief status bar flash.",
            "Suppress all toasts; errors flash in the status bar for 8 seconds."
          ],
          "default": "all",
          "description": "Controls how AI Agencee surfaces notifications. Change to 'errors-only' or 'silent' to reduce interruptions."
        },
        "ai-agencee.preferLocalModels": {
          "type": "boolean",
          "default": false,
          "description": "Only use VS Code built-in models (GitHub Copilot). No external API calls."
        },
        "ai-agencee.ollamaEndpoint": {
          "type": "string",
          "default": "",
          "description": "Ollama endpoint for local embeddings (e.g. http://localhost:11434)"
        },
        "ai-agencee.toolApprovals": {
          "type": "string",
          "enum": [
            "ask",
            "always"
          ],
          "enumDescriptions": [
            "Always ask for permission before executing tools that modify the workspace (write_file, run_terminal, etc).",
            "Automatically approve all tool executions without prompting."
          ],
          "default": "ask",
          "description": "Determines whether Codernic should prompt for user approval before running mutating workspace tools."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "tsc -p tsconfig.build.json --noEmit && node esbuild.config.mjs && pnpm run copy:flows && pnpm run copy:structura && pnpm run build:webview",
    "build:webview": "vite build --config vite.webview.config.ts",
    "copy:flows": "node scripts/copy-flows.js",
    "copy:structura": "node scripts/copy-structura.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "dev:webview": "vite --config vite.webview.config.ts",
    "lint": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "package": "vsce package --no-dependencies",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "code:index": "agencee code:index --path .",
    "code:watch": "echo 'code:watch not yet implemented in agencee CLI — use agencee code:index'",
    "code:search": "echo 'code:search not yet implemented in agencee CLI — use the Codernic search panel'",
    "code:stats": "echo 'code:stats not yet implemented in agencee CLI'"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@atomos-web/prime": "^2.0.0",
    "@atomos-web/prime-style": "^2.0.0",
    "@atomos-web/structura": "^2.0.0",
    "@atomos-web/structura-core": "^2.0.0",
    "@atomos-web/structura-mcp": "^2.0.0",
    "@binaryjack/formular.dev": "^1.0.58",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "mermaid": "^11.14.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@ai-agencee/ui": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.118.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vscode/vsce": "^3.9.1",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.25.12",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "ws": "^8.21.0"
  }
}
